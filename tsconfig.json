{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "noCheck": true,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/ui", "vite.config.ts", "vitest.config.ts"]
}
